# Ozon API Configuration
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
# Пауза между запросами к Ozon Seller API (сек)
# OZON_REQUEST_MIN_INTERVAL_SEC=0.25

# Wildberries API Configuration
WB_API_KEY=your_wildberries_api_key

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Scheduler Configuration
SCHEDULER_INTERVAL_MINUTES=60

# Report Configuration
# Время уведомлений (несколько через запятую)
REPORT_NOTIFICATION_TIMES=09:00,14:00,18:00
# Диапазон времени суток для отчёта (ЧЧ:ММ)
REPORT_RANGE_START=00:00
REPORT_RANGE_END=23:59

# Database Configuration (для будущей миграции на PostgreSQL)
# DATABASE_URL=sqlite:///./mpinformer.db
# Для PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/mpinformer

# Logging
LOG_LEVEL=INFO

# Server Configuration
SERVER_PORT=8001

# Очередь поставок Ozon (bundle-состав): пауза после запроса (сек), число параллельных запросов
# SUPPLY_QUEUE_BUNDLE_DELAY_SEC=0.15
# SUPPLY_QUEUE_BUNDLE_MAX_CONCURRENT=3

# Админка (логин и пароль для входа на /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Секрет подписи cookie-сессий (сайт /admin и /login). Сгенерируйте случайную строку, не оставляйте дефолт на проде.
# Пример: openssl rand -hex 32
SESSION_SECRET_KEY=change_me_to_random_long_string
